#!/usr/bin/env bash
set -eu

usage() {
  cat <<'USAGE'
usage: setup [--mount PATH] [--print-env]

Checks local Mycelium setup and optionally creates a mount directory.
Does not download binaries. If mycelium is missing, install the project release
binary or build from source, then re-run doctor.
USAGE
}

mount=""
print_env=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    --mount)
      [ "$#" -ge 2 ] || { printf 'error: --mount requires PATH\n' >&2; exit 2; }
      mount="$2"
      shift 2
      ;;
    --print-env)
      print_env=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'error: unexpected argument: %s\n' "$1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if ! command -v mycelium >/dev/null 2>&1; then
  cat >&2 <<'MSG'
error: mycelium is not on PATH

Install a released binary from the Mycelium project, or build from source:
  make build
  install cmd/mycelium/mycelium /usr/local/bin/mycelium
MSG
  exit 1
fi

if [ -n "$mount" ]; then
  mkdir -p "$mount"
  export MYCELIUM_MOUNT="$mount"
elif [ -z "${MYCELIUM_MOUNT:-}" ]; then
  printf 'error: set MYCELIUM_MOUNT or pass --mount PATH\n' >&2
  exit 1
fi

if [ "$print_env" -eq 1 ]; then
  printf 'export MYCELIUM_MOUNT=%q\n' "$MYCELIUM_MOUNT"
fi

"$(dirname "$0")/doctor"
